KAFKA_HOST=localhost
KAFKA_PORT=9092

# Window configuration (seconds)
WINDOW_DURATION=60
SLIDE_INTERVAL_60=60
ALLOWED_LATENESS=10

# SKIP or ZERO_FILL
EMPTY_WINDOW_STRATEGY=SKIP

# Seconds of silence before a slice group is pruned from memory.
# Leave unset to disable pruning (default).
GROUP_TTL_SECONDS=

# Optional: start processing from a past Unix timestamp (historical replay).
# Leave unset to start from now.
START_TIME=
